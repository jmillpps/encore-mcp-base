{
  "id": "",
  "lang": "typescript",
  "global_cors": {
    "allow_headers": ["Authorization", "Content-Type", "Accept", "MCP-Protocol-Version", "MCP-Session-Id", "Last-Event-ID"],
    "expose_headers": ["WWW-Authenticate", "MCP-Session-Id"],
    "allow_origins_without_credentials": ["https://chatgpt.com", "https://chat.openai.com", "http://localhost:4000"],
    "allow_origins_with_credentials": ["https://chatgpt.com", "https://chat.openai.com", "http://localhost:4000"]
  }
}
