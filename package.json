{
  "name": "gpt-mcp-service",
  "private": true,
  "version": "0.1.0",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "encore run --browser=never --port=4000",
    "openapi": "node --experimental-strip-types tools/export-openapi.ts",
    "sync:actions-routes": "node --experimental-strip-types tools/sync-actions-route-manifest.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test --test-concurrency=1 \"test/**/*.test.ts\"",
    "check:actions-openapi": "node --experimental-strip-types tools/sync-actions-route-manifest.ts --check && node --experimental-strip-types tools/export-openapi.ts --base-url https://example.test --no-build > /dev/null",
    "check:architecture": "node --experimental-strip-types tools/check-architecture.ts",
    "check:dependencies": "node --experimental-strip-types tools/check-dependencies.ts",
    "check:file-scope": "node --experimental-strip-types tools/check-file-scope.ts",
    "check:test-placement": "node --experimental-strip-types tools/check-test-placement.ts",
    "check": "npm run typecheck && npm run check:dependencies && npm run check:architecture && npm run check:file-scope && npm run check:test-placement && npm run check:actions-openapi && npm test"
  },
  "dependencies": {
    "encore.dev": "1.57.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "oauth4webapi": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
